# ---------- Google login ----------
# Create in Google Cloud Console > APIs & Services > Credentials > OAuth Client ID (Web application)
GOOGLE_CLIENT_ID=
# Comma-separated allowlist, seeds the DB on first boot (editable later via Налаштування)
ALLOWED_GOOGLE_EMAILS=you@example.com

# ---------- Bootstrap secrets (must be env vars, needed before the DB is reachable) ----------
# openssl rand -hex 32
SESSION_SECRET=
# openssl rand -hex 32 (exactly 32 bytes / 64 hex chars)
ENCRYPTION_KEY=

# ---------- DOTmed Parser's own settings (seed values; editable later via Налаштування) ----------
DOTMED_EMAIL=
DOTMED_PASSWORD=
# Optional escape hatch: if this server's own IP/proxy can't get a session
# past Cloudflare, log in from a machine that can (e.g. a residential IP)
# and paste its resulting cookies here as a JSON array of "name=value"
# strings — used once at startup if no valid session already exists.
DOTMED_SESSION_COOKIES=
PROXY_CHANGE_IP_URL=https://changeip.mobileproxy.space/?proxy_key=REPLACE_ME
# Optional: a Cloudflare Worker reverse-proxying dotmed.com (edge-to-edge
# traffic gets past Cloudflare's bot checks more reliably than our own
# proxy for Firecrawl's per-listing scrapes, which never carry our session
# cookies). Leave unset to fetch dotmed.com directly as before.
DOTMED_PROXY_URL=

# ---------- dotmed-postgres (DOTmed Parser's own DB: settings + job history) ----------
DOTMED_POSTGRES_PASSWORD=

# ---------- Self-hosted Firecrawl (proxy for the page-fetch step only) ----------
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
BULL_AUTH_KEY=

# ---------- AI extraction (used directly by dotmed-parser, NOT Firecrawl) ----------
# Firecrawl only fetches/renders pages now; DOTmed Parser calls an OpenAI-
# compatible endpoint itself to extract structured listing data, so failures
# (bad model name, provider errors, invalid JSON) are visible in our own logs
# instead of silently swallowed inside Firecrawl's internal extraction step.
#
# Multiple independent providers can be configured — tried in order, each
# with its own model + optional fallback model, automatically skipping to
# the next provider on error/rate-limit/empty result. Provider 1 is required;
# providers 2-4 are optional (leave any provider's vars blank to skip it).
OPENAI_API_KEY=
OPENAI_BASE_URL=
MODEL_NAME=
MODEL_NAME_FALLBACK=

AI_PROVIDER2_BASE_URL=
AI_PROVIDER2_API_KEY=
AI_PROVIDER2_MODEL=
AI_PROVIDER2_MODEL_FALLBACK=

AI_PROVIDER3_BASE_URL=
AI_PROVIDER3_API_KEY=
AI_PROVIDER3_MODEL=
AI_PROVIDER3_MODEL_FALLBACK=

AI_PROVIDER4_BASE_URL=
AI_PROVIDER4_API_KEY=
AI_PROVIDER4_MODEL=
AI_PROVIDER4_MODEL_FALLBACK=

# ---------- Optional ----------
PORT=4000
# Set to "true" only if the app is reachable over real HTTPS (public domain + valid cert).
# Leave unset/false for plain-HTTP LAN/IP deployments — otherwise the login cookie
# will silently refuse to be sent and login will appear to do nothing.
COOKIE_SECURE=false
