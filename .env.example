# ---------- Google login ----------
# Create in Google Cloud Console > APIs & Services > Credentials > OAuth Client ID (Web application)
GOOGLE_CLIENT_ID=
# Comma-separated allowlist, seeds the DB on first boot (editable later via Налаштування)
ALLOWED_GOOGLE_EMAILS=you@example.com

# ---------- Bootstrap secrets (must be env vars, needed before the DB is reachable) ----------
# openssl rand -hex 32
SESSION_SECRET=
# openssl rand -hex 32 (exactly 32 bytes / 64 hex chars)
ENCRYPTION_KEY=

# ---------- DOTmed Parser's own settings (seed values; editable later via Налаштування) ----------
DOTMED_EMAIL=
DOTMED_PASSWORD=
PROXY_CHANGE_IP_URL=https://changeip.mobileproxy.space/?proxy_key=REPLACE_ME

# ---------- dotmed-postgres (DOTmed Parser's own DB: settings + job history) ----------
DOTMED_POSTGRES_PASSWORD=

# ---------- Self-hosted Firecrawl (proxy + AI extraction provider) ----------
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
OPENAI_API_KEY=
OPENAI_BASE_URL=
# Firecrawl defaults this to "gpt-4" if unset — if your OPENAI_BASE_URL provider
# doesn't serve a model under that exact name, JSON extraction silently comes
# back empty (page fetches fine, AI extraction step fails). Set explicitly.
MODEL_NAME=
BULL_AUTH_KEY=

# ---------- Optional ----------
PORT=4000
# Set to "true" only if the app is reachable over real HTTPS (public domain + valid cert).
# Leave unset/false for plain-HTTP LAN/IP deployments — otherwise the login cookie
# will silently refuse to be sent and login will appear to do nothing.
COOKIE_SECURE=false
